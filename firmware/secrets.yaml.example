#  ESPHome Secrets Template
# Instructions: 
# 1. Rename this file to 'secrets.yaml'
# 2. Add your REAL credentials below.
# 3. The .gitignore will ensure 'secrets.yaml' is never uploaded to GitHub.

# --- WiFi Credentials ---
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# --- API & OTA Security ---
api_password: "YOUR_API_PASSWORD"
ota_password: "YOUR_OTA_PASSWORD"
api_encryption_key: "YOUR_API_ENCRYPTION_KEY"

# --- ESP-NOW Mesh MAC Addresses ---
# Required for Node 1 and Node 2 to securely tunnel data. 
# Retrieve these from the initial ESPHome boot logs before compiling.
node1_mac: "XX:XX:XX:XX:XX:XX"
node2_mac: "XX:XX:XX:XX:XX:XX"

# --- Static IPs (Optional) ---
# node1_ip: 192.168.1.101
# node3_ip: 192.168.1.103
